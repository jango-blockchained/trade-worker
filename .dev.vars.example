# Trade Worker Environment Variables (local development)
# Copy to .dev.vars and replace with actual values from `hoox setup` output.
# .dev.vars is gitignored — never commit secrets.

# Internal auth key for service-to-service authentication
INTERNAL_KEY_BINDING=your_internal_key_binding_here

# Scoped keys (recommended): execute vs read separation
# TRADE_EXECUTE_KEY_BINDING=your_trade_execute_key_here
# TRADE_READ_KEY_BINDING=your_trade_read_key_here

# Telegram internal key for sending trade notifications
TELEGRAM_INTERNAL_KEY_BINDING=your_telegram_internal_key_here

# Exchange API keys (required for trade execution)
# MEXC_KEY_BINDING=your_mexc_api_key_here
# MEXC_SECRET_BINDING=your_mexc_api_secret_here
# BINANCE_KEY_BINDING=your_binance_api_key_here
# BINANCE_SECRET_BINDING=your_binance_api_secret_here
# BYBIT_KEY_BINDING=your_bybit_api_key_here
# BYBIT_SECRET_BINDING=your_bybit_api_secret_here
