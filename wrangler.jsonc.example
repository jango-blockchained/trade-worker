{
  // Trade Worker — multi-exchange execution engine
  "name": "trade-worker",
  "account_id": "YOUR_ACCOUNT_ID",
  "main": "src/index.ts",
  "alias": {
    "@jango-blockchained/hoox-shared/errors": "../../packages/shared/src/errors.ts",
    "@jango-blockchained/hoox-shared/middleware": "../../packages/shared/src/middleware/index.ts",
    "@jango-blockchained/hoox-shared/router": "../../packages/shared/src/router.ts",
    "@jango-blockchained/hoox-shared/types": "../../packages/shared/src/types.ts",
    "@jango-blockchained/hoox-shared/types/router": "../../packages/shared/src/types/router.ts",
    "@jango-blockchained/hoox-shared/analytics": "../../packages/shared/src/analytics.ts",
    "@jango-blockchained/hoox-shared/health": "../../packages/shared/src/health.ts",
    "@jango-blockchained/hoox-shared/kvKeys": "../../packages/shared/src/kvKeys.ts",
    "@jango-blockchained/hoox-shared/exchange-client": "../../packages/shared/src/exchange-client.ts"
  },
  "compatibility_date": "2026-06-08",
  "compatibility_flags": ["nodejs_compat"],
  "placement": {
    "mode": "smart"
  },
  "observability": {
    "enabled": true,
    "logs": { "enabled": true, "head_sampling_rate": 1 },
    "traces": { "enabled": true, "head_sampling_rate": 0.01 }
  },
  // NOTE: All secrets set via `wrangler secret put <NAME>`.
  // Never commit actual secret values.
  "vars": {
    // Secrets - create via: wrangler secret put INTERNAL_KEY_BINDING
    // wrangler secret put MEXC_KEY_BINDING && MEXC_SECRET_BINDING
    // wrangler secret put BINANCE_KEY_BINDING && BINANCE_SECRET_BINDING
    // wrangler secret put BYBIT_KEY_BINDING && BYBIT_SECRET_BINDING
    // wrangler secret put TELEGRAM_INTERNAL_KEY_BINDING
  },
  "services": [
    {
      "binding": "D1_SERVICE",
      "service": "d1-worker"
    },
    {
      "binding": "TELEGRAM_SERVICE",
      "service": "telegram-worker"
    },
    {
      "binding": "ANALYTICS_SERVICE",
      "service": "analytics-worker"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "CONFIG_KV",
      "id": "YOUR_CONFIG_KV_ID"
    }
  ],
  "r2_buckets": [
    {
      "binding": "REPORTS_BUCKET",
      "bucket_name": "trade-reports"
    },
    {
      "binding": "SYSTEM_LOGS_BUCKET",
      "bucket_name": "hoox-system-logs"
    }
  ],
  "queues": {
    "consumers": [
      {
        "queue": "trade-execution",
        "max_retries": 3,
        "dead_letter_queue": "trade-execution-dlq"
      }
    ]
  }
}
